rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      // Safely check if the user exists and has an 'admin' role.
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Admins can read any user document.
      // Users can only read their own document.
      allow get: if request.auth.uid == userId || isAdmin();

      // Admins can list all users.
      // Public leaderboard reads are served via a server endpoint that returns
      // only public profile fields (displayName, photoURL, points).
      // Listing all users directly is admin-only.
      allow list: if isAdmin();

      // Users can create their own document upon signup.
      allow create: if request.auth.uid == userId;

      // Users can update their own document, but cannot change their role.
      // Admins can update any user document, including changing the role.
      allow update: if (request.auth.uid == userId && request.resource.data.role == resource.data.role) || isAdmin();

      // Only admins can delete users.
      allow delete: if isAdmin();
    }

    // Rules for the 'opportunities' collection
    match /opportunities/{opportunityId} {
      // Admins can read any opportunity.
      // Authenticated users can read approved opportunities.
      // Users can read their own submitted opportunities.
      allow get: if isAdmin() || resource.data.status == 'approved' || resource.data.ownerId == request.auth.uid;

      // Admins can list all opportunities.
      // Authenticated users may only list approved opportunities or their
      // own documents — this prevents exposing other users' pending items.
      allow list: if isAdmin()
        || (
          request.auth.uid != null && (
            request.query.where('status','==','approved') ||
            request.query.where('ownerId','==', request.auth.uid)
          )
        );


      // Authenticated users can create new opportunities.
      allow create: if request.auth.uid != null;

      // Admins can update any opportunity.
      // The owner of an opportunity can update it if it's still pending.
      allow update: if isAdmin() || (resource.data.ownerId == request.auth.uid && resource.data.status == 'pending');

      // Admins or the owner can delete an opportunity.
      allow delete: if isAdmin() || resource.data.ownerId == request.auth.uid;
    }

    // Rules for the 'sponsoredChallenges' collection
    match /sponsoredChallenges/{challengeId} {
      // Admins can read any challenge.
      // Authenticated users can read approved challenges.
      // Users can read their own submitted challenges.
      allow get: if isAdmin() || resource.data.status == 'approved' || resource.data.creatorUid == request.auth.uid;

      // Admins can list all challenges.
      // Authenticated users may only list approved challenges or their
      // own documents — this prevents exposing other users' pending items.
      allow list: if isAdmin()
        || (
          request.auth.uid != null && (
            request.query.where('status','==','approved') ||
            request.query.where('creatorUid','==', request.auth.uid)
          )
        );

      // Authenticated users can create new challenges.
      allow create: if request.auth.uid != null;

      // Admins can update any challenge.
      // The creator of a challenge can update it if it's still pending.
      allow update: if isAdmin() || (resource.data.creatorUid == request.auth.uid && resource.data.status == 'pending');

      // Admins or the creator can delete a challenge.
      allow delete: if isAdmin() || resource.data.creatorUid == request.auth.uid;
    }

    // Wall Posts
    match /wallPosts/{postId} {
      // Allow anyone to read
      allow read: if true;

      // Allow authenticated users to create
      allow create: if request.auth.uid != null;

      // Allow owner or admin to update/delete
      allow update, delete: if resource.data.uid == request.auth.uid || isAdmin();
    }

    // Quotes
    match /quotes/{quoteId} {
        // Allow anyone to read
        allow read: if true;
        // Restrict writes to admins
        allow write: if isAdmin();
    }

    // Rules for the 'games' collection
    match /games/{gameId} {
      allow read, write: if request.auth.uid != null;
    }
    
    // Rules for video chat
    match /videoRooms/{roomId} {
      // Allow authenticated users to create, read, update, and delete rooms.
      allow read, write: if request.auth.uid != null;

      // Rules for the 'signals' subcollection for WebRTC
      match /signals/{signalId} {
        // Allow authenticated users to exchange signaling messages.
        allow read, write: if request.auth.uid != null;
      }
    }

    // Financial ledger — server-only (Admin SDK), no client access
    match /financialLedger/{entryId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Stripe processed events — server-only idempotency store
    match /stripeProcessedEvents/{eventId} {
      allow read, write: if false;
    }

    // Stripe webhook logs — admin read, server write
    match /stripeWebhookLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Payment records — admin read, server write
    match /payments/{paymentId} {
      allow read: if isAdmin() || resource.data.ownerUid == request.auth.uid;
      allow write: if false;
    }

    // Payment logs — admin read, server write
    match /paymentLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Payouts — admin only
    match /payouts/{payoutId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // System alerts — admin only
    match /systemAlerts/{alertId} {
      allow read: if isAdmin();
      allow update: if isAdmin();
      allow create, delete: if false;
    }

    // Rate limits — server-only
    match /rateLimits/{bucketId} {
      allow read, write: if false;
    }

    // Admin audit logs — admin read, server write
    match /adminAuditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Security logs — admin read, server write
    match /securityLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Data access logs — admin read, server write
    match /dataAccessLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Order collections — admin full access, owner read
    match /sponsoredChallengeOrders/{orderId} {
      allow read: if isAdmin() || resource.data.creatorUid == request.auth.uid;
      allow write: if false;
    }

    match /creatorBoostOrders/{orderId} {
      allow read: if isAdmin() || resource.data.ownerUid == request.auth.uid;
      allow write: if false;
    }

    match /institutionAccounts/{accountId} {
      allow read: if isAdmin() || resource.data.ownerUid == request.auth.uid;
      allow write: if false;
    }

    match /sponsoredOpportunityOrders/{orderId} {
      allow read: if isAdmin() || resource.data.ownerUid == request.auth.uid;
      allow write: if false;
    }

    match /placementReports/{reportId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}