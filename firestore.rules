rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow get: if request.auth.uid == userId || isAdmin();
      allow list: if isAdmin();
      allow create: if request.auth.uid == userId;
      allow update: if (request.auth.uid == userId && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if isAdmin();
    }

    match /presence/{userId} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid == userId;
    }

    match /opportunities/{opportunityId} {
      allow get: if isAdmin() || resource.data.status == 'approved' || resource.data.ownerId == request.auth.uid;
      allow list: if isAdmin()
        || (
          request.auth.uid != null && (
            request.query.where('status','==','approved') ||
            request.query.where('ownerId','==', request.auth.uid)
          )
        );
      allow create: if request.auth.uid != null;
      allow update: if isAdmin() || (resource.data.ownerId == request.auth.uid && resource.data.status == 'pending');
      allow delete: if isAdmin() || resource.data.ownerId == request.auth.uid;
    }

    match /sponsoredChallenges/{challengeId} {
      allow get: if isAdmin() || resource.data.status == 'approved' || resource.data.creatorUid == request.auth.uid;
      allow list: if isAdmin()
        || (
          request.auth.uid != null && (
            request.query.where('status','==','approved') ||
            request.query.where('creatorUid','==', request.auth.uid)
          )
        );
      allow create: if request.auth.uid != null;
      allow update: if isAdmin() || (resource.data.creatorUid == request.auth.uid && resource.data.status == 'pending');
      allow delete: if isAdmin() || resource.data.creatorUid == request.auth.uid;
    }

    match /wallPosts/{postId} {
      allow read: if true;
      allow create: if request.auth.uid != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 150;
      allow update: if (resource.data.uid == request.auth.uid || isAdmin())
        && request.resource.data.uid == resource.data.uid;
      allow delete: if resource.data.uid == request.auth.uid || isAdmin();
    }

    match /quotes/{quoteId} {
        allow read: if true;
        allow write: if isAdmin();
    }

    match /games/{gameId} {
      allow read: if request.auth.uid != null;
      allow create: if request.auth.uid != null;
      allow update: if request.auth.uid != null
        && (resource.data.hostId == request.auth.uid
            || request.auth.uid in resource.data.players
            || isAdmin());
      allow delete: if resource.data.hostId == request.auth.uid || isAdmin();
    }

    match /videoRooms/{roomId} {
      allow get: if request.auth.uid != null;
      allow list: if request.auth.uid != null && request.query.where('status', '==', 'waiting');
      allow create: if request.auth.uid != null;
      allow update: if request.auth.uid != null && (resource.data.userA == request.auth.uid || resource.data.userB == request.auth.uid || isAdmin());
      allow delete: if request.auth.uid != null && (resource.data.userA == request.auth.uid || isAdmin());

      match /signals/{signalId} {
        allow read, write: if request.auth.uid != null;
      }
    }

    match /financialLedger/{entryId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /paymentLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /refunds/{refundId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /operatingSpend/{spendId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /rateLimits/{limitId} {
      allow read, write: if false;
    }

    match /_healthcheck/{docId} {
      allow read, write: if false;
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /moderationQueue/{itemId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}